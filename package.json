{
  "name": "melovista",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "desktop": "npm run dev --workspace=apps/desktop",
    "mobile": "npm run android --workspace=apps/mobile",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luxaztk/Cross-Platform-Music-Player-App.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Melovista - Cross platform music player (Electron + React Native)",
  "bugs": {
    "url": "https://github.com/Luxaztk/Cross-Platform-Music-Player-App/issues"
  },
  "homepage": "https://github.com/Luxaztk/Cross-Platform-Music-Player-App#readme",
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "electron-updater": "^6.8.3",
    "prettier": "^3.8.1",
    "react-window": "^2.2.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "eslint": "^9.39.4"
  }
}
