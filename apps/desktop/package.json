{
  "name": "melovista-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node node_modules/youtube-dl-exec/scripts/postinstall.js || echo 'Warning: yt-dlp binary download failed!'",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@music/utils": "*",
    "@types/ffmpeg-installer__ffmpeg": "^1.0.2",
    "electron-store": "^10.1.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.6.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.2.0",
    "youtube-dl-exec": "^3.1.4",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "@vitest/coverage-v8": "^4.1.3",
    "vitest": "^4.1.3"
  },
  "build": {
    "appId": "com.melovista.app",
    "productName": "Melovista",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/@ffmpeg-installer/win32-x64/**",
      "**/node_modules/youtube-dl-exec/bin/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}