{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "esnext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Monorepo */
    "paths": {
      "@music/core": ["../../packages/core/src"],
      "@music/core/*": ["../../packages/core/src/*"],
      "@music/player": ["../../packages/player/src"],
      "@music/player/*": ["../../packages/player/src/*"],
      "@music/types": ["../../packages/types"],
      "@music/types/*": ["../../packages/types/*"],
      "@music/hooks": ["../../packages/hooks"],
      "@music/hooks/*": ["../../packages/hooks/*"],
      "@music/utils": ["../../packages/utils/src"],
      "@music/utils/*": ["../../packages/utils/src/*"],
      "@music/ui": ["../../packages/ui"],
      "@music/ui/*": ["../../packages/ui/*"],
      "@music/brand": ["../../packages/brand"],
      "@components": ["./src/presentations/components"],
      "@components/*": ["./src/presentations/components/*"],
      "@hooks": ["./src/application/hooks"],
      "@hooks/*": ["./src/application/hooks/*"],
      "@infrastructure": ["./src/infrastructure"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@utils": ["./src/infrastructure/utils"],
      "@utils/*": ["./src/infrastructure/utils/*"],
      "@constants": ["./src/presentations/constants"],
    }
  },
  "include": ["vite.config.ts", "electron/**/*.ts"]
}

