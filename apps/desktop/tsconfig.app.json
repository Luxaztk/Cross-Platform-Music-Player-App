{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node"],

    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Monorepo */
    "baseUrl": "../..",
    "paths": {
      "@music/core": ["packages/core/src/index.ts"],
      "@music/core/*": ["packages/core/src/*"],
      "@music/player": ["packages/player/src/index.ts"],
      "@music/player/*": ["packages/player/src/*"],
      "@music/types": ["packages/types/index.ts"],
      "@music/types/*": ["packages/types/*"],
      "@music/hooks": ["packages/hooks/index.ts"],
      "@music/hooks/*": ["packages/hooks/*"],
      "@music/utils": ["packages/utils/src/index.ts"],
      "@music/utils/*": ["packages/utils/src/*"],
      "@music/ui": ["packages/ui/index.ts"],
      "@music/ui/*": ["packages/ui/*"],
      "@music/brand": ["packages/brand"]
    }
  },
  "include": [
    "src",
    "../../packages/*/src",
    "../../packages/*/index.ts"
  ]
}
