{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "esnext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node"],

    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Monorepo */
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@music/core": ["../../packages/core/src/index.ts"],
      "@music/core/*": ["../../packages/core/src/*"],
      "@music/player": ["../../packages/player/src/index.ts"],
      "@music/player/*": ["../../packages/player/src/*"],
      "@music/types": ["../../packages/types/index.ts"],
      "@music/types/*": ["../../packages/types/*"],
      "@music/hooks": ["../../packages/hooks/index.ts"],
      "@music/hooks/*": ["../../packages/hooks/*"],
      "@music/utils": ["../../packages/utils/src/index.ts"],
      "@music/utils/*": ["../../packages/utils/src/*"],
      "@music/ui": ["../../packages/ui/index.ts"],
      "@music/ui/*": ["../../packages/ui/*"],
      "@music/brand": ["../../packages/brand"],
      "@components": ["./src/presentations/components/index.ts"],
      "@components/*": ["./src/presentations/components/*"],
      "@hooks": ["./src/application/hooks/index.ts"],
      "@hooks/*": ["./src/application/hooks/*"],
      "@infrastructure": ["./src/infrastructure/index.ts"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@utils": ["./src/infrastructure/utils/index.ts"],
      "@utils/*": ["./src/infrastructure/utils/*"],
      "@constants": ["./src/presentations/constants"],
    }
  },
  "include": [
    "src",
    "../../packages/*/src",
    "../../packages/*/index.ts"
  ]
}
