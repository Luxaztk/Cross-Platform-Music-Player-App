{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "@music/types": ["../../packages/types/src/index.ts"],
      "@music/types/*": ["../../packages/types/src/*"],
      "@music/utils": ["../../packages/utils/src/index.ts"],
      "@music/utils/*": ["../../packages/utils/src/*"],
      "@music/core": ["../../packages/core/src/index.ts"],
      "@music/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
